<div class="mx-auto min-h-screen max-w-screen-xl bg-[#0d0d0d] px-6 py-8">
  <header class="mb-6">
    <h1 class="text-2xl font-bold text-[#e6edf3]">Markets</h1>
    <p class="text-sm text-[#7d8590]">Explore prediction markets and their resolution risk scores</p>
  </header>

  <%= render Markets::MarketFiltersComponent.new(selected_risk: params[:risk].presence || "all", query: params[:q]) %>

  <%= turbo_frame_tag "markets_results" do %>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      <% @display_units.each do |unit| %>
        <%= render Markets::MarketCardComponent.new(market: unit[:market], total_volume: unit[:total_volume]) %>
      <% end %>
    </div>

    <div class="mt-8 flex items-center justify-center gap-4">
      <% if @pagination[:prev_page].present? %>
        <%= link_to "← Prev", root_path(request.query_parameters.merge(page: @pagination[:prev_page])), data: { turbo_frame: "markets_results" }, class: "no-underline rounded-full border border-[#2a2a2a] bg-[#1a1a1a] px-4 py-2 text-sm font-medium text-[#888888] transition-colors hover:border-[#3b82f6] hover:text-white" %>
      <% else %>
        <span class="rounded-full border border-[#2a2a2a] bg-[#1a1a1a] px-4 py-2 text-sm font-medium text-[#888888] opacity-50 cursor-default">← Prev</span>
      <% end %>
      <span class="text-sm text-[#888888]">Page <%= @pagination[:current_page] %> of <%= [@pagination[:total_pages], 1].max %></span>
      <% if @pagination[:next_page].present? %>
        <%= link_to "Next →", root_path(request.query_parameters.merge(page: @pagination[:next_page])), data: { turbo_frame: "markets_results" }, class: "no-underline rounded-full border border-[#2a2a2a] bg-[#1a1a1a] px-4 py-2 text-sm font-medium text-[#888888] transition-colors hover:border-[#3b82f6] hover:text-white" %>
      <% else %>
        <span class="rounded-full border border-[#2a2a2a] bg-[#1a1a1a] px-4 py-2 text-sm font-medium text-[#888888] opacity-50 cursor-default">Next →</span>
      <% end %>
    </div>
  <% end %>
</div>
