<div class="mb-6 flex flex-wrap items-center gap-2 overflow-x-auto">
  <div class="flex shrink-0 gap-2">
    <% %w[all low medium high critical].each do |option| %>
      <%= link_to option.capitalize, filter_path(option), data: { turbo_frame: "markets_results" }, class: "no-underline #{pill_classes(option)}" %>
    <% end %>
  </div>
  <%= form_with url: helpers.root_path, method: :get, data: { turbo_frame: "markets_results" }, class: "ml-auto shrink-0" do |f| %>
    <%= hidden_field_tag :risk, @selected_risk if @selected_risk != "all" %>
    <%= text_field_tag :q, @query, placeholder: "Search markets...", class: "w-56 rounded-lg border border-[#2a2a2a] bg-[#1a1a1a] px-3 py-2 text-sm text-white placeholder:text-[#888888] focus:border-[#3b82f6] focus:outline-none focus:ring-1 focus:ring-[#3b82f6]", aria: { label: "Search markets" } %>
  <% end %>
</div>
