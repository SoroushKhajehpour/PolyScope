<div class="mb-6 flex flex-wrap items-center gap-2">
  <div class="flex shrink-0 gap-2 overflow-x-auto">
    <% %w[all low medium high critical].each do |option| %>
      <%= link_to option.capitalize, filter_path(option), data: { turbo_frame: "markets_results" }, class: "no-underline #{pill_classes(option)}" %>
    <% end %>
  </div>
  <div class="relative z-50 ml-auto shrink-0" id="live_search_wrapper" data-controller="live-search" data-live-search-url="<%= helpers.live_search_path %>" data-root-path="<%= helpers.root_path %>" data-selected-risk="<%= @selected_risk %>">
    <%= form_with url: helpers.root_path, method: :get, data: { turbo_frame: "markets_results" }, class: "block" do |f| %>
      <%= hidden_field_tag :risk, @selected_risk if @selected_risk != "all" %>
      <div class="relative">
        <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-[#888888]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <%= text_field_tag :q, @query, placeholder: "Search polymarkets...", id: "live_search_input", autocomplete: "off", class: "w-[28rem] min-w-96 rounded-lg border border-[#2a2a2a] bg-[#1a1a1a] py-2 pl-9 pr-3 text-sm text-white placeholder:text-[#888888] focus:border-[#3b82f6] focus:outline-none focus:ring-1 focus:ring-[#3b82f6]", aria: { label: "Search markets", expanded: "false", controls: "live_search_results" } %>
      </div>
    <% end %>
    <div id="live_search_results" data-live-search-panel class="absolute left-0 right-0 top-full z-[100] mt-0.5 hidden w-full max-w-full rounded-t-none rounded-b-lg border border-t-0 border-[#2a2a2a] bg-[#1a1a1a] shadow-xl shadow-black/50" aria-hidden="true" role="listbox" aria-labelledby="live_search_input">
      <div id="live_search_list" class="max-h-80 overflow-y-auto">
        <p class="px-4 py-4 text-center text-sm text-[#888888]" data-live-search-placeholder>Type to search</p>
      </div>
      <div class="border-t border-[#2a2a2a]">
        <%= link_to "See all results →", helpers.root_path(q: @query.presence, risk: @selected_risk != "all" ? @selected_risk : nil), id: "live_search_see_all", data: { turbo_frame: "markets_results" }, class: "block px-4 py-3 text-center text-sm font-medium text-[#3b82f6] hover:text-blue-400 hover:underline" %>
      </div>
    </div>
  </div>
</div>
<script>
(function() {
  // Single source of truth for the live search dropdown. Turbo Frame "markets_results" is only
  // used on form submit (Enter); this script controls the overlay via fetch(/live_search).
  var wrapper = document.getElementById('live_search_wrapper');
  if (!wrapper || wrapper.dataset.liveSearchBound === 'true') return;

  var panels = document.querySelectorAll('[data-live-search-panel]');
  if (panels.length > 1) {
    console.warn('[live-search] Multiple dropdown panels found, using the first.');
  }
  var panel = document.getElementById('live_search_results');
  var input = document.getElementById('live_search_input');
  var list = document.getElementById('live_search_list');
  var seeAll = document.getElementById('live_search_see_all');
  if (!wrapper || !input || !panel || !list) return;

  wrapper.dataset.liveSearchBound = 'true';

  var debounceTimer;
  var lastRequestId = 0;

  function show() {
    panel.classList.remove('hidden');
    panel.setAttribute('aria-hidden', 'false');
    input.setAttribute('aria-expanded', 'true');
    input.classList.remove('rounded-lg');
    input.classList.add('rounded-t-lg', 'rounded-b-none', 'border-b-0');
  }

  function hide() {
    panel.classList.add('hidden');
    panel.setAttribute('aria-hidden', 'true');
    input.setAttribute('aria-expanded', 'false');
    input.classList.remove('rounded-t-lg', 'rounded-b-none', 'border-b-0');
    input.classList.add('rounded-lg');
  }

  function setListContent(html) {
    list.innerHTML = html;
  }

  function setPlaceholder(text) {
    setListContent('<p class="px-4 py-4 text-center text-sm text-[#888888]" data-live-search-placeholder>' + (text || 'Type to search') + '</p>');
  }

  function fetchResults() {
    var q = input.value.trim();
    var baseUrl = wrapper.dataset.liveSearchUrl || '/live_search';
    var risk = wrapper.dataset.selectedRisk;
    if (q.length === 0) {
      setPlaceholder('Type to search');
      return;
    }
    setPlaceholder('Searching…');
    var reqId = ++lastRequestId;
    var params = new URLSearchParams({ q: q });
    if (risk && risk !== 'all') params.set('risk', risk);
    fetch(baseUrl + '?' + params.toString(), {
      headers: { 'Accept': 'text/html', 'X-Requested-With': 'XMLHttpRequest' }
    }).then(function(res) { return res.text(); }).then(function(html) {
      if (reqId !== lastRequestId) return;
      setListContent(html);
      if (seeAll) {
        var href = (wrapper.dataset.rootPath || '/') + '?q=' + encodeURIComponent(q);
        if (risk && risk !== 'all') href += '&risk=' + encodeURIComponent(risk);
        seeAll.href = href;
      }
    }).catch(function() {
      if (reqId !== lastRequestId) return;
      setPlaceholder('Search failed');
    });
  }

  function debouncedFetch() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(fetchResults, 250);
  }

  input.addEventListener('focus', function() {
    show();
    if (input.value.trim().length > 0) debouncedFetch();
  });
  input.addEventListener('input', function() {
    if (input.value.trim().length > 0) show();
    debouncedFetch();
  });

  input.addEventListener('blur', function() {
    setTimeout(function() {
      if (!wrapper.contains(document.activeElement)) hide();
    }, 150);
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') hide();
  });
})();
</script>
