<div class="flex cursor-pointer flex-col gap-3 rounded-xl border border-[#30363d] bg-[#161b22] p-4 transition-all duration-150 hover:bg-[#1c2330] hover:border-[#3b82f6] hover:shadow-[0_0_0_1px_#3b82f6]">
  <span class="self-start rounded-full border border-[#30363d] px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-[#7d8590]">
    <%= category %>
  </span>

  <div class="flex items-start gap-3">
    <div class="flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-lg bg-[#30363d]">
      <% if first_market&.image_url.present? %>
        <%= image_tag first_market.image_url, alt: "", class: "h-12 w-12 object-cover", loading: "lazy" %>
      <% else %>
        <svg class="h-5 w-5 text-[#7d8590]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
      <% end %>
    </div>
    <div class="min-w-0 flex-1">
      <p class="text-sm font-semibold leading-snug text-[#e6edf3]">
        <%= @title %>
      </p>
      <div class="mt-2 <%= 'max-h-32 overflow-y-auto' if scrollable? %> flex flex-col gap-1.5">
        <% market_rows.each do |row| %>
          <div class="flex items-center justify-between gap-2 text-xs">
            <span class="min-w-0 truncate text-[#e6edf3]" title="<%= row[:question] %>"><%= row[:question] %></span>
            <span class="shrink-0 font-semibold text-[#7d8590]"><%= row[:probability_text] %></span>
            <span class="shrink-0 text-[#7d8590]"><%= row[:formatted_volume] %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="border-t border-[#30363d]"></div>

  <div class="flex justify-between text-xs text-[#7d8590]">
    <span><%= formatted_total_volume %> Vol.</span>
    <span><%= formatted_end_date %></span>
  </div>
</div>
