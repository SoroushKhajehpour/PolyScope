<a href="#" class="flex cursor-pointer flex-col gap-3 rounded-xl border border-[#30363d] bg-[#161b22] p-4 transition-all duration-150 hover:bg-[#1c2330] hover:border-[#3b82f6] hover:shadow-[0_0_0_1px_#3b82f6]">
  <span class="self-start rounded-full border border-[#30363d] px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-[#7d8590]">
    <%= category %>
  </span>

  <div class="flex items-start gap-3">
    <div class="flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-lg bg-[#30363d]">
      <% if @market.image_url.present? %>
        <%= image_tag @market.image_url, alt: "", class: "h-12 w-12 object-cover", loading: "lazy" %>
      <% else %>
        <svg class="h-5 w-5 text-[#7d8590]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
      <% end %>
    </div>
    <p class="min-w-0 flex-1 line-clamp-3 text-sm font-semibold leading-snug text-[#e6edf3]">
      <%= @market.question %>
    </p>
    <% if @market.market_type == "binary" && binary_percentage.present? %>
      <div class="flex shrink-0 flex-col items-center leading-tight" aria-hidden="true">
        <span class="text-lg font-bold" style="color: <%= binary_bar_color %>"><%= binary_percentage %></span>
        <span class="text-[10px] text-[#7d8590]">chance</span>
      </div>
    <% elsif @market.market_type == "multi_outcome" && multi_outcome_entries.any? %>
      <div class="shrink-0 w-24 <%= 'max-h-20 overflow-y-auto' if multi_outcome_scrollable? %> flex flex-col gap-1 text-right">
        <% multi_outcome_entries.each do |entry| %>
          <div class="flex items-center justify-end gap-2 text-[#e6edf3]">
            <span class="min-w-0 truncate text-xs" title="<%= entry[:label] %>"><%= entry[:label] %></span>
            <span class="text-xs font-semibold text-[#7d8590]"><%= format('%.0f%%', entry[:probability] * 100) %></span>
          </div>
        <% end %>
      </div>
    <% elsif @market.market_type == "scalar" && scalar_range.present? %>
      <div class="shrink-0 flex flex-col items-end gap-1 w-24">
        <span class="text-sm font-bold text-[#e6edf3]"><%= formatted_scalar_value(scalar_range[:current]) %></span>
        <span class="text-[10px] text-[#7d8590]"><%= formatted_scalar_value(scalar_range[:min]) %> – <%= formatted_scalar_value(scalar_range[:max]) %></span>
        <% if scalar_range_percent.present? %>
          <div class="w-full h-1.5 rounded-full bg-[#30363d] overflow-hidden" aria-hidden="true">
            <div class="h-full rounded-full bg-[#3b82f6]" style="width: <%= scalar_range_percent %>%"></div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="flex items-center gap-2">
    <span class="flex items-center gap-1 rounded-full px-2 py-0.5 text-xs font-bold <%= risk_pill_classes %>">
      <span class="h-1.5 w-1.5 rounded-full bg-current"></span>
      <%= risk_label %>
    </span>
    <span class="text-xs text-[#7d8590]">Score: <%= risk_score_value || "—" %></span>
  </div>

  <div class="border-t border-[#30363d]"></div>

  <div class="flex justify-between text-xs text-[#7d8590]">
    <span><%= formatted_volume %> Vol.</span>
    <span><%= formatted_end_date %></span>
  </div>
</a>
